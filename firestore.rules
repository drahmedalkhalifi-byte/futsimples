rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthed() {
      return request.auth != null;
    }

    function mySchoolId() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.schoolId;
    }

    function sameSchool(docSchoolId) {
      return isAuthed() && docSchoolId == mySchoolId();
    }

    // ── Users ────────────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read, write: if isAuthed() && request.auth.uid == userId;
    }

    // ── Schools ──────────────────────────────────────────────────────────────
    // Public read so parent portal can show school name.
    // create: any authenticated user can create a NEW school (needed during
    //         first-time setup, before the user document exists).
    // update/delete: only the school's own admin (user doc must already exist).
    match /schools/{schoolId} {
      allow read: if true;
      allow create: if isAuthed();
      allow update, delete: if sameSchool(schoolId);
    }

    // ── Students ─────────────────────────────────────────────────────────────
    // Portal access is handled server-side via /api/portal/[token] (Firebase Admin).
    // Client-side reads are restricted to authenticated users of the same school.
    match /students/{docId} {
      allow read:   if sameSchool(resource.data.schoolId);
      allow create: if isAuthed() && request.resource.data.schoolId == mySchoolId();
      allow update: if isAuthed() && resource.data.schoolId == mySchoolId();
      allow delete: if isAuthed() && resource.data.schoolId == mySchoolId();
    }

    // ── Payments ─────────────────────────────────────────────────────────────
    // Portal access is handled server-side via /api/portal/[token] (Firebase Admin).
    match /payments/{docId} {
      allow read:   if sameSchool(resource.data.schoolId);
      allow create: if isAuthed() && request.resource.data.schoolId == mySchoolId();
      allow update: if isAuthed() && resource.data.schoolId == mySchoolId();
      allow delete: if isAuthed() && resource.data.schoolId == mySchoolId();
    }

    // ── Attendances ──────────────────────────────────────────────────────────
    // Portal access is handled server-side via /api/portal/[token] (Firebase Admin).
    match /attendances/{docId} {
      allow read:   if sameSchool(resource.data.schoolId);
      allow create: if isAuthed() && request.resource.data.schoolId == mySchoolId();
      allow update: if isAuthed() && resource.data.schoolId == mySchoolId();
      allow delete: if isAuthed() && resource.data.schoolId == mySchoolId();
    }

    // ── Schedules ────────────────────────────────────────────────────────────
    // Portal access is handled server-side via /api/portal/[token] (Firebase Admin).
    match /schedules/{docId} {
      allow read:   if sameSchool(resource.data.schoolId);
      allow create: if isAuthed() && request.resource.data.schoolId == mySchoolId();
      allow update: if isAuthed() && resource.data.schoolId == mySchoolId();
      allow delete: if isAuthed() && resource.data.schoolId == mySchoolId();
    }

    // ── Expenses ─────────────────────────────────────────────────────────────
    match /expenses/{docId} {
      allow read: if sameSchool(resource.data.schoolId);
      allow create: if isAuthed() && request.resource.data.schoolId == mySchoolId();
      allow update: if isAuthed() && resource.data.schoolId == mySchoolId();
      allow delete: if isAuthed() && resource.data.schoolId == mySchoolId();
    }

    // ── Championships ────────────────────────────────────────────────────────
    match /championships/{docId} {
      allow read: if sameSchool(resource.data.schoolId);
      allow create: if isAuthed() && request.resource.data.schoolId == mySchoolId();
      allow update: if isAuthed() && resource.data.schoolId == mySchoolId();
      allow delete: if isAuthed() && resource.data.schoolId == mySchoolId();
    }
  }
}
